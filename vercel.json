{
  "version": 2,
  "builds": [
    {
      "src": "api/chat.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/songs.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/playlists.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/favorites.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "/api/chat.js"
    },
    {
      "src": "/api/songs",
      "dest": "/api/songs.js"
    },
    {
      "src": "/api/playlists",
      "dest": "/api/playlists.js"
    },
    {
      "src": "/api/favorites",
      "dest": "/api/favorites.js"
    }
  ]
}
